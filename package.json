{
  "name": "@antonycc/oidc",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "app/oidc"
  ],
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.873.0",
    "@aws-sdk/lib-dynamodb": "^3.873.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0",
    "ulid": "^2.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "aws-cdk": "^2.1026.0",
    "dotenv": "^17.2.1",
    "dotenv-cli": "^9.0.0",
    "eslint": "^9.34.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "./mvnw clean package",
    "update-to-minor": "npx npm-check-updates --upgrade --enginesNode --target minor --verbose --install always",
    "update-to-greatest": "npx npm-check-updates --upgrade --enginesNode --target greatest --verbose --install always --reject 'alpha'",
    "formatting": "prettier --check . && ./mvnw spotless:check",
    "formatting-fix": "prettier --write . && ./mvnw spotless:apply",
    "cdk": "docker build -t oidc-base:latest -f Dockerfile . && npm run build && npx dotenv -e .env.prod -- npx cdk synth CognitoStack-prod --require-approval never --ci true --strict --validation && ./scripts/clean-tests.sh",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "clean": "./scripts/clean-tests.sh",
    "provision:user": "node app/bin/provision-user.mjs",
    "clear:users": "node app/bin/clear-users.mjs"
  },
  "overrides": {
    "yocto-queue": "^1.0.0",
    "p-limit": "^5.0.0",
    "p-queue": "^8.0.0"
  }
}
