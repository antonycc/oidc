{
  "name": "@antonycc/oidc",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": { "node": ">=20" },
  "workspaces": [
    "app/oidc-provider"
  ],
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.614.0",
    "@aws-sdk/lib-dynamodb": "^3.614.0",
    "ulid": "^2.3.0",
    "jose": "^5.9.4",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "@playwright/test": "^1.40.0"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "provision:user": "node app/oidc-provider/scripts/provision-user.mjs",
    "clear:users": "node app/oidc-provider/scripts/clear-users.mjs"
  }
}