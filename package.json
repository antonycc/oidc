{
  "name": "@antonycc/oidc",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "app/oidc"
  ],
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.886.0",
    "@aws-sdk/lib-dynamodb": "^3.886.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0",
    "ulid": "^2.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.1",
    "aws-cdk": "^2.1029.0",
    "dotenv": "^17.2.2",
    "dotenv-cli": "^9.0.0",
    "eslint": "^9.35.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.6.2",
    "uuid": "^13.0.0",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "./mvnw clean package",
    "update-to-minor": "npx npm-check-updates --upgrade --enginesNode --target minor --verbose --install always",
    "update-to-greatest": "npx npm-check-updates --upgrade --enginesNode --target greatest --verbose --install always --reject 'alpha'",
    "formatting": "prettier --check . && ./mvnw spotless:check",
    "formatting-fix": "prettier --write . && ./mvnw spotless:apply",
    "formatting:js": "prettier --check .",
    "formatting:js-fix": "prettier --write .",
    "formatting:java": "./mvnw spotless:check",
    "formatting:java-fix": "./mvnw spotless:apply",
    "docker:build": "docker build -t oidc-base:latest -f Dockerfile .",
    "cdk:synth": "npm run build && npx dotenv -e .env.prod -- npx cdk synth ProviderStack-prod --require-approval never --ci true --strict --validation",
    "cdk": "npm run docker:build && npm run cdk:synth ; npm run clean",
    "test": "npm run test:unit && npm run test:system",
    "test:unit": "vitest run",
    "test:system": "vitest run app/system",
    "test:web": "npx dotenv -e .env -- playwright test tests/web.live.test.ts",
    "test:web:ui": "npx dotenv -e .env -- playwright test --ui tests/web.live.test.ts",
    "test:web:headed": "npx dotenv -e .env -- playwright test --headed tests/web.live.test.ts",
    "test:api": "npx dotenv -e .env -- playwright test tests/api.live.test.ts",
    "clean": "./scripts/clean-tests.sh",
    "users:provision": "node app/bin/provision-user.mjs",
    "users:clear": "node app/bin/clear-users.mjs",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "openapi:validate": "node scripts/validate-openapi.mjs",
    "openapi:test": "node scripts/test-openapi-local.mjs"
  },
  "overrides": {
    "yocto-queue": "^1.0.0",
    "p-limit": "^5.0.0",
    "p-queue": "^8.0.0"
  }
}
